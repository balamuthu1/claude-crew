{
  "id": "product",
  "displayName": "Product Management",
  "description": "PRD authoring, user story writing, and product strategy specialist agents. Includes jira-integration skill for direct JIRA ticket creation via jira-cli.",
  "version": "2.0.0",
  "agents": [
    "prd-author",
    "user-story-writer",
    "product-manager",
    "metrics-analyst",
    "stakeholder-advisor"
  ],
  "commands": [
    "prd",
    "user-story",
    "feature-brief",
    "acceptance-criteria",
    "metrics-review",
    "detect-product-stack"
  ],
  "skills": [
    "product-discovery",
    "prd-writing",
    "story-mapping",
    "jira-integration"
  ],
  "rules": [
    "product-standards.md"
  ],
  "configTemplate": "product.config.md",
  "detectCommand": "detect-product-stack",
  "permissions": {
    "allow": [
      "Bash(jira *)"
    ],
    "deny": []
  },
  "securityGuardrails": {
    "additionalSensitiveFilePatterns": [],
    "hooksModule": "product"
  },
  "compatibleWith": ["mobile", "backend", "frontend", "qa", "data"],
  "conflictsWith": []
}

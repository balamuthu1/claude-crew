{
  "description": "Claude Crew — Mobile Agent Harness for Android & iOS teams",
  "version": "2.0.0",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-tool-use.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use.sh\""
          }
        ]
      }
    ]
  },

  "permissions": {
    "allow": [
      "Bash(./gradlew *)",
      "Bash(swift *)",
      "Bash(xcodebuild *)",
      "Bash(bundle exec fastlane *)",
      "Bash(adb *)",
      "Bash(swiftlint *)",
      "Bash(pod install)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  }
}
